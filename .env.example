# ==============================================================================
# BlowCortex — Environment Variables Template
# ==============================================================================
# Copy this file to .env.local and fill in your credentials.
# See external-services-setup.md for instructions on obtaining each value.
# NEVER commit .env.local to git. It is gitignored for your safety.
# ==============================================================================

# ------------------------------------------------------------------------------
# Core
# ------------------------------------------------------------------------------
NODE_ENV=development
CORTEX_BASE_URL=http://localhost:3000
CORTEX_API_URL=http://localhost:3100

# AES-256 encryption key for OAuth tokens at rest.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# ------------------------------------------------------------------------------
# OpenRouter (LLM provider — core dependency)
# ------------------------------------------------------------------------------
# Single endpoint giving access to 300+ models (Anthropic, OpenAI, Google, Meta,
# Mistral, DeepSeek, etc.) with built-in pricing/routing/fallback. The full list
# is fetched dynamically at runtime via GET /api/v1/models — never hardcode IDs.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional attribution headers (shown in OpenRouter analytics + leaderboards).
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_X_TITLE=BlowCortex

# Default model slug used when the user has not picked one in settings.
# Examples: anthropic/claude-sonnet-4.5, openai/gpt-4o-mini, google/gemini-2.5-pro,
# deepseek/deepseek-chat, meta-llama/llama-3.3-70b-instruct.
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4.5

# Hard ceiling on max_tokens per request. The user-facing setting may lower it
# but never raise it above this value. Acts as a safety net against runaway cost.
OPENROUTER_MAX_TOKENS=4096

# ------------------------------------------------------------------------------
# Clerk (authentication)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_PUBLIC_KEY=
CLERK_WEBHOOK_SECRET=

# Clerk URLs (defaults work for dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ------------------------------------------------------------------------------
# Database (Supabase or Neon)
# ------------------------------------------------------------------------------
# Pooled URL (runtime)
DATABASE_URL=
# Direct URL (migrations)
DATABASE_DIRECT_URL=

# ------------------------------------------------------------------------------
# Redis (Upstash with Redis Stack for vector search)
# ------------------------------------------------------------------------------
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ------------------------------------------------------------------------------
# Zep Cloud (temporal knowledge graph)
# ------------------------------------------------------------------------------
ZEP_API_KEY=
ZEP_API_URL=https://api.getzep.com

# ------------------------------------------------------------------------------
# Inngest (event orchestration)
# ------------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ------------------------------------------------------------------------------
# Observability
# ------------------------------------------------------------------------------
# Langfuse (LLM tracing)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Sentry (error tracking)
SENTRY_DSN_WEB=
SENTRY_DSN_API=
SENTRY_DSN_MOBILE=
SENTRY_ORG=
SENTRY_PROJECT_WEB=cortex-web
SENTRY_PROJECT_API=cortex-api
SENTRY_PROJECT_MOBILE=cortex-mobile
SENTRY_AUTH_TOKEN=

# ------------------------------------------------------------------------------
# Google Cloud (Gmail + Calendar — Phase 1 Sprint 2+)
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI_DEV=http://localhost:3100/v1/connectors/google/oauth/callback
GOOGLE_REDIRECT_URI_PROD=

# Gmail Pub/Sub (real-time email webhooks)
GCP_PROJECT_ID=
GMAIL_PUBSUB_TOPIC=

# ------------------------------------------------------------------------------
# Slack (Phase 2)
# ------------------------------------------------------------------------------
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ------------------------------------------------------------------------------
# Notion (Phase 2)
# ------------------------------------------------------------------------------
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=

# ------------------------------------------------------------------------------
# Cloudflare R2 (object storage)
# ------------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cortex-artifacts-dev
R2_ENDPOINT=
