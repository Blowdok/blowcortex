# ==============================================================================
# BlowCortex — Modèle de variables d'environnement
# ==============================================================================
# Copier ce fichier vers .env.local et renseigner vos identifiants.
# Voir external-services-setup.md pour obtenir chaque valeur.
# NE JAMAIS committer .env.local dans git. Il est ignoré par git pour votre sécurité.
# ==============================================================================

# ------------------------------------------------------------------------------
# Cœur
# ------------------------------------------------------------------------------
NODE_ENV=development
BLOWCORTEX_BASE_URL=http://localhost:3000
BLOWCORTEX_API_URL=http://localhost:3100

# Clé de chiffrement AES-256 pour les tokens OAuth au repos.
# Générer avec : openssl rand -base64 32
ENCRYPTION_KEY=

# ------------------------------------------------------------------------------
# OpenRouter (fournisseur LLM — dépendance principale)
# ------------------------------------------------------------------------------
# Point d'entrée unique donnant accès à plus de 300 modèles (Anthropic, OpenAI, Google, Meta,
# Mistral, DeepSeek, etc.) avec tarification/routage/fallback intégrés. La liste complète
# est récupérée dynamiquement à l'exécution via GET /api/v1/models — ne jamais coder en dur les IDs.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# En-têtes d'attribution optionnels (visibles dans les analytics et classements OpenRouter).
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_X_TITLE=BlowCortex

# Slug du modèle par défaut quand l'utilisateur n'en a pas choisi dans ses paramètres.
# Exemples : anthropic/claude-sonnet-4.5, openai/gpt-4o-mini, google/gemini-2.5-pro,
# deepseek/deepseek-chat, meta-llama/llama-3.3-70b-instruct.
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4.5

# Plafond strict sur max_tokens par requête. Le paramètre utilisateur peut l'abaisser
# mais jamais le dépasser. Agit comme filet de sécurité contre les coûts incontrôlés.
OPENROUTER_MAX_TOKENS=4096

# ------------------------------------------------------------------------------
# Clerk (authentification)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_PUBLIC_KEY=
CLERK_WEBHOOK_SECRET=

# URLs Clerk (les valeurs par défaut conviennent en dev)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ------------------------------------------------------------------------------
# Base de données (Supabase ou Neon)
# ------------------------------------------------------------------------------
# URL avec pool de connexions (exécution)
DATABASE_URL=
# URL directe (migrations)
DATABASE_DIRECT_URL=

# ------------------------------------------------------------------------------
# Redis (Upstash avec Redis Stack pour la recherche vectorielle)
# ------------------------------------------------------------------------------
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ------------------------------------------------------------------------------
# Zep Cloud (graphe de connaissances temporel)
# ------------------------------------------------------------------------------
ZEP_API_KEY=
ZEP_API_URL=https://api.getzep.com

# ------------------------------------------------------------------------------
# Inngest (orchestration d'événements)
# ------------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ------------------------------------------------------------------------------
# Observabilité
# ------------------------------------------------------------------------------
# Langfuse (traçage LLM)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Sentry (suivi des erreurs)
SENTRY_DSN_WEB=
SENTRY_DSN_API=
SENTRY_DSN_MOBILE=
SENTRY_ORG=
SENTRY_PROJECT_WEB=cortex-web
SENTRY_PROJECT_API=cortex-api
SENTRY_PROJECT_MOBILE=cortex-mobile
SENTRY_AUTH_TOKEN=

# ------------------------------------------------------------------------------
# Google Cloud (Gmail + Calendar — Phase 1 Sprint 2+)
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI_DEV=http://localhost:3100/v1/connectors/google/oauth/callback
GOOGLE_REDIRECT_URI_PROD=

# Gmail Pub/Sub (webhooks d'emails en temps réel)
GCP_PROJECT_ID=
GMAIL_PUBSUB_TOPIC=

# ------------------------------------------------------------------------------
# Slack (Phase 2)
# ------------------------------------------------------------------------------
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# ------------------------------------------------------------------------------
# Notion (Phase 2)
# ------------------------------------------------------------------------------
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=

# ------------------------------------------------------------------------------
# Cloudflare R2 (stockage d'objets)
# ------------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cortex-artifacts-dev
R2_ENDPOINT=
