# Configuration pnpm pour ce monorepo
# https://pnpm.io/npmrc

# Approche stricte des dépendances pour éviter les imports fantômes
shamefully-hoist=false
strict-peer-dependencies=true

# Compatibilité Node 22 (semver exact requis par pnpm)
node-version=22.17.1
use-node-version=22.17.1

# Utiliser la version exacte des dépendances plutôt que ^/~
save-exact=true

# Toujours installer depuis le workspace en priorité
prefer-workspace-packages=true
link-workspace-packages=deep

# Autoriser les scripts post-install pour les paquets natifs vérifiés
# (ex. esbuild, sharp). Ceux non listés exigent une autorisation manuelle via
# `pnpm approve-builds`.
# https://pnpm.io/settings#onlybuiltdependencies
