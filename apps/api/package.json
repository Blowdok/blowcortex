{
  "name": "@blowcortex/api",
  "version": "0.0.1",
  "private": true,
  "description": "API HTTP BlowCortex (Hono sur Node.js).",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.local src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=../../.env.local dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@blowcortex/core": "workspace:*",
    "@blowcortex/db": "workspace:*",
    "@hono/node-server": "1.13.7",
    "@hono/zod-validator": "0.4.2",
    "hono": "4.6.16",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@blowcortex/config": "workspace:*",
    "@types/node": "22.10.5",
    "eslint": "9.18.0",
    "rimraf": "6.0.1",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
