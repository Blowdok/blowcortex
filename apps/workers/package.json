{
  "name": "@blowcortex/workers",
  "version": "0.0.1",
  "private": true,
  "description": "Fonctions Inngest : agents, ingestion, exécution d'actions.",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.local src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=../../.env.local dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@blowcortex/core": "workspace:*",
    "@hono/node-server": "1.13.7",
    "hono": "4.6.16",
    "inngest": "3.29.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@blowcortex/config": "workspace:*",
    "@types/node": "22.10.5",
    "eslint": "9.18.0",
    "rimraf": "6.0.1",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
