{
  "name": "blowcortex",
  "version": "0.0.1",
  "private": true,
  "description": "Système d'IA proactive qui observe la vie professionnelle de l'utilisateur, comprend son contexte et agit en son nom.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.18.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@blowcortex/web",
    "dev:api": "turbo run dev --filter=@blowcortex/api",
    "dev:workers": "turbo run dev --filter=@blowcortex/workers",
    "inngest:dev": "inngest-cli dev -u http://localhost:3100/api/inngest",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test -- --watch",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md,json,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,md,json,yml,yaml}\" --ignore-path .gitignore",
    "db:generate": "turbo run db:generate --filter=@blowcortex/db",
    "db:migrate": "turbo run db:migrate --filter=@blowcortex/db",
    "db:studio": "turbo run db:studio --filter=@blowcortex/db",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "docker:logs": "docker compose -f infra/docker/docker-compose.yml logs -f",
    "clean": "turbo run clean && rimraf node_modules .turbo"
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "prettier": "3.4.2",
    "rimraf": "6.0.1",
    "turbo": "2.3.3",
    "typescript": "5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@swc/core",
      "@tailwindcss/oxide"
    ],
    "overrides": {
      "@types/react": "19.1.4",
      "@types/react-dom": "19.1.4"
    },
    "peerDependencyRules": {
      "ignoreMissing": ["react", "react-dom"]
    }
  }
}
