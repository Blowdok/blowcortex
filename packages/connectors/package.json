{
  "name": "@blowcortex/connectors",
  "version": "0.0.1",
  "private": true,
  "description": "Clients MCP, flux OAuth et adaptateurs pour les services tiers (Gmail, Calendar, Slack, Notion).",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@blowcortex/core": "workspace:*",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@blowcortex/config": "workspace:*",
    "@types/node": "22.10.5",
    "eslint": "9.18.0",
    "rimraf": "6.0.1",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
