{
  "name": "@blowcortex/db",
  "version": "0.0.1",
  "private": true,
  "description": "Schéma Drizzle, migrations et client Postgres pour BlowCortex.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@blowcortex/core": "workspace:*",
    "drizzle-orm": "0.38.3",
    "postgres": "3.4.5"
  },
  "devDependencies": {
    "@blowcortex/config": "workspace:*",
    "@types/node": "22.10.5",
    "dotenv": "16.4.7",
    "drizzle-kit": "0.30.1",
    "eslint": "9.18.0",
    "rimraf": "6.0.1",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
